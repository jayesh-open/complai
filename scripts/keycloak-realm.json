{
  "id": "complai",
  "realm": "complai",
  "enabled": true,
  "displayName": "Complai",
  "displayNameHtml": "<strong>Complai</strong>",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "roles": {
    "realm": [
      {
        "name": "complai-admin",
        "description": "Full platform administrator"
      },
      {
        "name": "tenant-admin",
        "description": "Tenant-level administrator"
      },
      {
        "name": "preparer",
        "description": "Can prepare filings and entries"
      },
      {
        "name": "reviewer",
        "description": "Can review and approve filings"
      },
      {
        "name": "viewer",
        "description": "Read-only access"
      },
      {
        "name": "vendor",
        "description": "External vendor portal access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "complai-web",
      "name": "Complai Web Application",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:3000",
      "baseUrl": "http://localhost:3000",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://localhost:3002/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001",
        "http://localhost:3002"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "complai-api",
      "name": "Complai API (Service Account)",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "secret": "dev-api-client-secret",
      "attributes": {
        "access.token.lifespan": "600"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "tenant-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "dev-admin",
      "email": "admin@complai.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Dev",
      "lastName": "Admin",
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "complai-admin"
      ]
    },
    {
      "username": "dev-preparer",
      "email": "preparer@complai.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Dev",
      "lastName": "Preparer",
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "preparer",
          "temporary": false
        }
      ],
      "realmRoles": [
        "preparer"
      ]
    }
  ],
  "scopeMappings": [],
  "clientScopeMappings": {},
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@complai.dev",
    "fromDisplayName": "Complai Dev",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  }
}
